# ===== Runtime =====
APP_ENV=server

# World persistent storage root (mounted disk)
WORLD_DATA_ROOT=/world/RENAISSANCEWORLD
# Optional fallback when WORLD_DATA_ROOT unavailable (must be outside project)
WORLD_DATA_FALLBACK_ROOT=/home/your-user/.renaiss_world_data/RENAISSANCEWORLD

# First boot migration:
# 1 = if ./data has old files and WORLD_DATA_ROOT is empty, auto copy once
# 0 = disable auto migration
WORLD_DATA_MIGRATE_ONCE=1

# ===== Daily remote backup =====
WORLD_BACKUP_ENABLED=1
WORLD_BACKUP_PROVIDER=git

# --- Git provider ---
# Private repo URL.
# Option A (HTTPS + PAT): https://x-access-token:<YOUR_GITHUB_PAT>@github.com/Gavinzip/renaiss_world_data.git
# Option B (SSH): git@github.com:Gavinzip/renaiss_world_data.git
WORLD_BACKUP_REPO=https://x-access-token:<YOUR_GITHUB_PAT>@github.com/Gavinzip/renaiss_world_data.git

WORLD_BACKUP_BRANCH=main
WORLD_BACKUP_SUBDIR=RENAISSANCEWORLD

# Keep backup clone outside WORLD_DATA_ROOT to avoid recursion
WORLD_BACKUP_REPO_DIR=/world/.renaiss_world_data_repo

# --- Google Drive provider ---
# Switch to Drive by setting WORLD_BACKUP_PROVIDER=gdrive
# Backup target folder id (open folder URL and copy the id after /folders/)
# Example: https://drive.google.com/drive/folders/1abcDEF...
WORLD_BACKUP_DRIVE_FOLDER_ID=

# Optional shared drive id (leave empty for personal My Drive)
WORLD_BACKUP_DRIVE_ID=

# Auth mode: auto | service_account | oauth_user
# auto: prefer oauth_user when client_id/client_secret/refresh_token are present
WORLD_BACKUP_DRIVE_AUTH_MODE=auto

# Option 1) OAuth user refresh token (same Google account as owner)
WORLD_BACKUP_DRIVE_CLIENT_ID=
WORLD_BACKUP_DRIVE_CLIENT_SECRET=
WORLD_BACKUP_DRIVE_REFRESH_TOKEN=

# Option 2) Service account JSON
WORLD_BACKUP_DRIVE_SERVICE_ACCOUNT_FILE=
# WORLD_BACKUP_DRIVE_SERVICE_ACCOUNT_JSON=
# WORLD_BACKUP_DRIVE_SERVICE_ACCOUNT_JSON_BASE64=

# Optional tuning
WORLD_BACKUP_DRIVE_SCOPE=https://www.googleapis.com/auth/drive
WORLD_BACKUP_DRIVE_RETENTION_COUNT=30
WORLD_BACKUP_DRIVE_FILE_PREFIX=world_backup_
WORLD_BACKUP_DRIVE_LATEST_POINTER_NAME=latest_world_backup.json

# Daily run time
WORLD_BACKUP_TIMEZONE=Asia/Taipei
WORLD_BACKUP_HOUR=0
WORLD_BACKUP_MINUTE=0

# Optional: run one backup right after bot starts
WORLD_BACKUP_RUN_ON_STARTUP=1

# Commit identity
WORLD_BACKUP_GIT_NAME=Renaiss World Bot
WORLD_BACKUP_GIT_EMAIL=bot@renaiss.world

# ===== AI runtime concurrency =====
# Recommended server default: 20
# Code fallback default when env missing: 20
AI_GLOBAL_CONCURRENCY=20
AI_RATE_LIMIT_RETRIES=5
AI_RATE_LIMIT_RETRY_DELAY_MS=1000

# SQLite lock wait time (milliseconds)
SQLITE_BUSY_TIMEOUT_MS=5000
