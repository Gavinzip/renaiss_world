# ===== Runtime =====
APP_ENV=server

# World persistent storage root (mounted disk)
WORLD_DATA_ROOT=/world/RENAISSANCEWORLD
# Optional fallback when WORLD_DATA_ROOT unavailable (must be outside project)
WORLD_DATA_FALLBACK_ROOT=/home/your-user/.renaiss_world_data/RENAISSANCEWORLD

# First boot migration:
# 1 = if ./data has old files and WORLD_DATA_ROOT is empty, auto copy once
# 0 = disable auto migration
WORLD_DATA_MIGRATE_ONCE=1

# ===== Daily git backup (private repo) =====
WORLD_BACKUP_ENABLED=1

# Private repo URL.
# Option A (HTTPS + PAT): https://x-access-token:<YOUR_GITHUB_PAT>@github.com/Gavinzip/renaiss_world_data.git
# Option B (SSH): git@github.com:Gavinzip/renaiss_world_data.git
WORLD_BACKUP_REPO=https://x-access-token:<YOUR_GITHUB_PAT>@github.com/Gavinzip/renaiss_world_data.git

WORLD_BACKUP_BRANCH=main
WORLD_BACKUP_SUBDIR=RENAISSANCEWORLD

# Keep backup clone outside WORLD_DATA_ROOT to avoid recursion
WORLD_BACKUP_REPO_DIR=/world/.renaiss_world_data_repo

# Daily run time
WORLD_BACKUP_TIMEZONE=Asia/Taipei
WORLD_BACKUP_HOUR=0
WORLD_BACKUP_MINUTE=0

# Optional: run one backup right after bot starts
WORLD_BACKUP_RUN_ON_STARTUP=1

# Commit identity
WORLD_BACKUP_GIT_NAME=Renaiss World Bot
WORLD_BACKUP_GIT_EMAIL=bot@renaiss.world
